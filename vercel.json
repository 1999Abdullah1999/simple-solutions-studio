{
  "version": 2,
  "framework": null,
  "installCommand": null,
  "buildCommand": "echo 'static deploy - no build needed'",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/md-anki.html" }
  ],
  "headers": [
    {
      "source": "/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
